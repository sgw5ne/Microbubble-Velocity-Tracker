ultrasound_app/
│── main.py                # Entry point: launches the app
│
├── gui/                   # User Interface (PyQt/PySide)
│   ├── __init__.py
│   ├── main_window.py     # Main window class (menus, buttons, video display)
│   ├── video_widget.py    # Widget for displaying ultrasound frames
│   └── controls.py        # Sliders, parameter inputs, buttons
│
├── processing/            # Video/image processing algorithms
│   ├── __init__.py
│   ├── video_reader.py    # OpenCV VideoCapture wrapper
│   ├── filters.py         # Filtering (denoising, contrast, speckle reduction)
│   ├── analysis.py        # Algorithms (motion tracking, segmentation, etc.)
│   └── metrics.py         # Compute heart rate, Doppler spectrum, etc.
│
├── utils/                 # Helper functions
│   ├── __init__.py
│   ├── file_io.py         # Open/save videos, configs, results
│   └── plotting.py        # PyQtGraph/Matplotlib plotting
│
├── tests/                 # Unit tests for processing modules
│   ├── test_filters.py
│   ├── test_analysis.py
│   └── test_metrics.py
│
└── requirements.txt       # Dependencies (PyQt5/PySide6, OpenCV, NumPy, etc.)
